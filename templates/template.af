
DESEQ_og_D){
	source ~soft_bio_267/initializes/init_degenes_hunter
	export PATH=$script_dir:$PATH
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D

	retVal=$?
       if [ $retVal -ne 0 ]; then
           echo ERROR: Last command exited with code $retVal
           exit $retVal
       fi
}

DESEQ_migrated_D){
	source ~aestebanm/projects/Hunter_hepatocytes/scripts/init_Hunter_dev
	export PATH=~aestebanm/dev_R/ExpHunterSuite/inst/scripts:$PATH
	export PATH=$script_dir:$PATH
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D

	retVal=$?
       if [ $retVal -ne 0 ]; then
           echo ERROR: Last command exited with code $retVal
           exit $retVal
       fi
}

