	export annotation_list=lol
	export clean_parentals=TRUE
	export universe=big
	export ADD_OPTIONS='--model_organism mmus --annot_file this_is_not_it --input_gene_id ENSEMBL --func_annot_db cibeles --GO_subont FP --custom what --analysis good --remote ALWAYS --clean_parentals FALSE --pthreshold 1 --qthreshold 1 --max_genes_plot 0 --cores 69 --task_size 420 --universe on_fire'
	?
	generate_DGHunter_command.R -m "functional_Hunter" > command
	echo -e "\n" >> command
	test=`diff command $data_dir"/func_add_command"`
	if [ "$test" != "" ]; then
		echo "Command generated is not what it should be"
		exit 1
	fi
}

generate_targets){
	source ~aestebanm/software/inits/init_Hunter_dev
	?
	generate_targets.R -o ./ -e experiment_design -t 'ctrl_vs_pat_all_nopat66>condition:control,patient' \
					   -b $data_dir"/blacklist_pat66" --aux_options ""
}

generate_targets_add_ft){
	source ~aestebanm/software/inits/init_Hunter_dev
	string_features="phenotype,genotype"
	numeric_features="age,height"
	?
	generate_targets.R -o ./ -e experiment_design -t 'ctrl_vs_pat_all_nopat66>condition:control,patient' \
					   -b $data_dir"/blacklist_pat66" --additional_features "$string_features,$numeric_features" \
					   --aux_options \"'-S $string_features -N $numeric_features'\"
}
