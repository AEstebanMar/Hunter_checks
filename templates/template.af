
Hunter_D){
	source ~/software/inits/init_Hunter_dev
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D
	retVal=$?
    if [ $retVal -ne 0 ]; then
        echo ERROR: DEGenes Hunter exited with cosde $retVal
        exit $retVal
    fi
}

