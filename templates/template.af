degsynth_vanilla){
	source ~/software/inits/init_Hunter_dev
	?
	degsynth.R -m compcodeR --samples.per.cond 24 -n 14760 -d 0 \
	--fraction.upregulated 0.5 -o synth --dataset="dataset" --output_dir ./ \
	--seed 69 --between.group.diffdisp FALSE
	retVal=$?
    if [ $retVal -ne 0 ]; then
       echo ERROR: DEG synthesis failed with code $retVal
       exit $retVal
    fi
    rm *diff
    rm compare_counts
    tail -n +2 synth_counts.tsv > compare_counts
    counts_diff=`diff compare_count $synth_data_dir"/vanilla_counts"`
	if [ "$counts_diff" != "" ] ; then
		echo "Output is not equal to snapshots"
		echo $counts_diff > counts_diff
		exit 1
	fi
	echo "Success!"
}

degsynth_[norm;exp;det]){
	source ~/software/inits/init_Hunter_dev
	?
	degsynth.R --inputfile $synth_data_dir"/input_counts" -m compcodeR \
	--samples.per.cond 6 --effect_sizes 1,2 \
	-n 14760 --fraction.upregulated 0.5 -o synth \
	--dataset="dataset" --output_dir ./ --ndegs "338,338" \
	--seed 69 --overlap_size 0.6 --condition_columns "2,3" --exp_design $synth_data_dir"/exp_design" \
	--fixed_DEG_lists $synth_data_dir"/degs1,"$synth_data_dir"/degs2" \
	--fixed_upregulated_DEGs $synth_data_dir"/up_degs_condition,"$synth_data_dir"/up_degs_condition2" \
	--method (*)
	retVal=$?
	if [ $retVal -ne 0 ]; then
       echo ERROR: DEG synthesis failed with code $retVal
       exit $retVal
    fi
    rm *diff
	counts_diff=`diff synth_counts.tsv $synth_data_dir"/(*)_counts"`
	if [ "$counts_diff" != "" ] || [ "$exp_diff" != "" ] ; then
		echo "Output is not equal to snapshots"
		echo $counts_diff > counts_diff
		exit 1
	else
		echo "Success!"
	fi
}

generate_DGHunter_command_DEG_env){
	source ~/software/inits/init_Hunter_dev
	export de_pvalue=1
	export de_packages="DELNW"
	export de_min_pack=3
	export de_logfc=0.05
	export WGCNA_mergecutHeight=50
	export WGCNA_min_genes_cluster=5
	export WGCNA_detectcutHeight=40
	export WGCNA_deepsplit=20
	export min_reads=10
	export filter_type="strict"
	export min_libraries=6
	export string_features="env_feature"
	export numeric_features="env_num_feature"
	export target_path=$data_dir"/ctrl_vs_pat_all_nopat66_target.txt"
	export query_genes="one,two,three_genes"
	export seed=69
	export count_var_quantile=0
	export deseq2_var_quantile=0
	?
	generate_DGHunter_command.R -m "degenes_Hunter" > command
	echo -e "\n" >> command
	test=`diff command $data_dir"/deg_env_command"`
	if [ "$test" != "" ]; then
		echo "Command generated is not what it should be"
		exit 1
	fi
}

generate_DGHunter_command_DEG_add){
	source ~/software/inits/init_Hunter_dev
	export de_pvalue=1
	export de_packages="DELNW"
	export de_min_pack=3
	export de_logfc=0.05
	export WGCNA_mergecutHeight=50
	export WGCNA_min_genes_cluster=5
	export WGCNA_detectcutHeight=40
	export WGCNA_deepsplit=20
	export min_reads=10
	export filter_type="strict"
	export min_libraries=6
	export string_features="env_feature"
	export numeric_features="env_num_feature"
	export target_path=$data_dir"/ctrl_vs_pat_all_nopat66_target.txt"
	export query_genes="one,two,three_genes"
	export seed=69
	export count_var_quantile=0
	export deseq2_var_quantile=0
	export ADD_OPTIONS='--Control_columns "ctrl1,ctrl2,ctrl3" --Treatment_columns "treat1,treat2,treat3" --reads 20 --minlibraries 16 --filter_type "lax" --p_val_cutoff 0 --lfc 0.5 --modules E --minpack_common 6 --target_file ./ctrl_vs_pat_all_nopat66_target.txt --external_DEA_file path/to/DEA/file --model_variables "yes" --string_factors "added_string_Fact" --numeric_factors "added_num_fact" --WGCNA_memory 14 --WGCNA_norm_method "added_wcgna_norm_method" --WGCNA_deepsplit 152 --WGCNA_min_genes_cluster 1 --WGCNA_detectcutHeight 1 --WGCNA_mergecutHeight 1 --WGCNA_all TRUE --WGCNA_blockwiseNetworkType "yes" --WGCNA_blockwiseTOMType "yes" --WGCNA_minCoreKME -4 --WGCNA_minCoreKMESize 1 --WGCNA_minKMEtoStay 1 --WGCNA_corType "easy" --multifactorial "whynot" --query_genes "every,gene,ever" --seed 420 --count_var_quantile 200 --deseq2_var_quantile 200'
	?
	generate_DGHunter_command.R -m "degenes_Hunter" > command
	echo -e "\n" >> command
	test=`diff command $data_dir"/deg_add_command"`
	if [ "$test" != "" ]; then
		echo "Command generated is not what it should be"
		exit 1
	fi
}

generate_DGHunter_command_func_env){
	source ~/software/inits/init_Hunter_dev
	export fun_remote_mode=NEVER
	export custom_nomenclature=this_is_it
	export fun_an_type=beautiful
	export GO_modules=BP,MF,CC
	export fun_an_performance=bad
	export fun_pvalue=0.05
	export fun_organism=hsa
	export annotation_list=lol
	export clean_parentals=TRUE
	export universe=big
	?
	generate_DGHunter_command.R -m "functional_Hunter" > command
	echo -e "\n" >> command
	test=`diff command $data_dir"/func_env_command"`
	if [ "$test" != "" ]; then
		echo "Command generated is not what it should be"
		exit 1
	fi
}

generate_DGHunter_command_func_add){
	source ~/software/inits/init_Hunter_dev
	export fun_remote_mode=NEVER
	export custom_nomenclature=this_is_it
	export fun_an_type=beautiful
