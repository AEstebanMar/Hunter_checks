Hunter_D_library_sizes){
	module load latex/3.14
	source ~aestebanm/initializes/init_Hunter_dev
	export DEGHUNTER_MODE=DEVELOPMENT
	export OMP_NUM_THREADS=1
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D --library_sizes $library_sizes
	retVal=$?
    if [ $retVal -ne 0 ]; then
        echo ERROR: Last command exited with code $retVal
        exit $retVal
    fi
}

