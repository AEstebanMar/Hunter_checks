
Hunter_og_D){
	source ~soft_bio_267/initializes/init_degenes_hunter
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D
	retVal=$?
    if [ $retVal -ne 0 ]; then
        echo ERROR: Last command exited with code $retVal
        exit $retVal
    fi
}

Hunter_migrated_D){
	source ~aestebanm/initializes/init_Hunter_dev
	?
	degenes_Hunter.R -i $input -o ./ -t $target -m D
	retVal=$?
    if [ $retVal -ne 0 ]; then
        echo ERROR: Last command exited with cosde $retVal
        exit $retVal
    fi
}

