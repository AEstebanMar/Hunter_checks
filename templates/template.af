multivar_mine_og){
	source ~soft_bio_267/initializes/init_degenes_hunter_alpha
	?
	multivar_mine.R "$multivar_data/metabolomics.txt,$multivar_data/phenotypes.txt,$multivar_data/severity_scales.txt" -A "metabolomics.txt:s,phenotypes.txt:n" -S "severity_scales.txt:c" -c -n 2
	retVal=$?
	if [ $retVal -ne 0 ]; then
       echo ERROR: Last command exited with code $retVal
       exit $retVal
   	fi
}

